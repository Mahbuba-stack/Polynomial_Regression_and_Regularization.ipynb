        "## Task 1 (25 points)\n",
        "**Implement Batch Gradient Descent from scratch** for a 4nd-degree polynomial regression on a new synthetic dataset (use different coefficients and noise from tutorial).\n",
        "\n",
        "### Requirements\n",
        "- Generate your own dataset.\n",
        "- Build polynomial features (degree 4).\n",
        "- Train using Batch GD.\n",
        "- Plot fitted curve and learning curve."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "task1-starter-code",
      "metadata": {
        "id": "task1-starter-code"
      },
      "outputs": [],
      "source": [
        "# -----------------------------\n",
        "# Task 1: Batch Gradient Descent for Degree-4 Polynomial\n",
        "# -----------------------------\n",
        "\n",
        "# 1. Generate synthetic dataset (new coefficients + noise)\n",
        "n_samples = 120\n",
        "x_t1 = np.linspace(-3, 3, n_samples)\n",
        "\n",
        "# True polynomial: y = a + b*x + c*x^2 + d*x^3 + e*x^4 + noise\n",
        "a, b, c, d, e = 2.0, -1.5, 0.8, -0.3, 0.1\n",
        "noise = np.random.normal(0, 2.0, size=n_samples)\n",
        "\n",
        "y_t1 = a + b*x_t1 + c*x_t1**2 + d*x_t1**3 + e*x_t1**4 + noise\n",
        "\n",
        "# reshape for sklearn\n",
        "X = x_t1.reshape(-1, 1)\n",
        "\n",
        "# 2. Polynomial features (degree 4) + scaling\n",
        "poly = PolynomialFeatures(degree=4, include_bias=False)\n",
        "X_poly = poly.fit_transform(X)\n",
        "\n",
        "scaler = StandardScaler()\n",
        "X_poly_scaled = scaler.fit_transform(X_poly)\n",
        "\n",
        "# Add bias manually (column of 1s)\n",
        "X_b = np.c_[np.ones((n_samples, 1)), X_poly_scaled]\n",
        "\n",
        "# 3. Batch Gradient Descent implementation\n",
        "def compute_cost(X, y, theta):\n",
        "    m = len(y)\n",
        "    predictions = X.dot(theta)\n",
        "    return (1/(2*m)) * np.sum((predictions - y)**2)\n",
        "\n",
        "def batch_gradient_descent(X, y, lr=0.05, n_iters=1000):\n",
        "    m, n = X.shape\n",
        "    theta = np.zeros(n)\n",
        "    cost_history = []\n",
        "\n",
        "    for i in range(n_iters):\n",
        "        gradients = (1/m) * X.T.dot(X.dot(theta) - y)\n",
        "        theta -= lr * gradients\n",
        "\n",
        "        cost = compute_cost(X, y, theta)\n",
        "        cost_history.append(cost)\n",
        "\n",
        "    return theta, cost_history\n",
        "\n",
        "# Train\n",
        "start_time = time.time()\n",
        "theta, cost_history = batch_gradient_descent(X_b, y_t1, lr=0.05, n_iters=1500)\n",
        "end_time = time.time()\n",
        "\n",
        "print(f\"Training completed in {end_time - start_time:.4f} seconds\")\n",
        "\n",
        "# 4. Predictions for smooth curve\n",
        "x_plot = np.linspace(-3, 3, 200).reshape(-1, 1)\n",
